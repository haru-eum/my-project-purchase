EXCHANGE_RATE_API_KEY={OPTIONAL_LEGACY_BOK_KEY}
OPENAI_API_KEY={YOUR_OPENAI_API_KEY}
# 참고: API 키가 없어도 yfinance로 구리/니켈/원유/천연가스/환율은 자동 수집됩니다.

